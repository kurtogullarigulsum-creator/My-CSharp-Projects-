{
    toplam += i;
}
double ortalama = (toplam / sayi);
if (ortalama > 50)
{
    Console.WriteLine("ORTALAMANIZ 50'DEN BÜYÜKTÜR"+ "ORTALAMANIZ: " + ortalama);
    Console.ReadLine();
}
else
{
    Console.WriteLine("ORTALAMANIZ 50'DEN KÜÇÜKTÜR."+ "ORTALAMANIZ: " + ortalama);
    Console.ReadLine();
}
